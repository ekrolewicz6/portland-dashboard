# Portland Commons Dashboard — ETL Environment Variables

# PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/portland_commons

# Census API (free key: https://api.census.gov/data/key_signup.html)
CENSUS_API_KEY=your_census_api_key_here

# BLS API v2 (register: https://www.bls.gov/developers/home.htm)
BLS_API_KEY=your_bls_api_key_here

# TriMet Developer API (register: https://developer.trimet.org/)
TRIMET_APP_ID=your_trimet_app_id_here

# Placer.ai (partnership/subscription)
PLACER_API_KEY=your_placer_api_key_here
PLACER_BASE_URL=https://api.placer.ai/v1

# Alert/notification (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
ALERT_EMAIL=dashboard-alerts@portlandcommons.org

# ETL behavior
ETL_LOG_LEVEL=INFO
ETL_DATA_DIR=./data
ETL_MAX_RETRIES=3
ETL_RETRY_DELAY_SECONDS=60

# Staging schema (tables land here before promotion)
ETL_STAGING_SCHEMA=staging
ETL_PRODUCTION_SCHEMA=public
