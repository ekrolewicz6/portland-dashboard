# === Portland Commons Dashboard — Environment Variables ===
# Copy this file to .env.local and fill in your values.

# --- Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/portland_dashboard
DATABASE_URL_UNPOOLED=postgresql://postgres:password@localhost:5432/portland_dashboard

# --- Next.js ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Mapbox ---
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- External APIs ---
TRIMET_APP_ID=
CENSUS_API_KEY=
BLS_API_KEY=

# --- Placer.ai (if direct subscription) ---
PLACER_API_KEY=

# --- Email Digest (Portland Pulse) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
PULSE_FROM_EMAIL=
PULSE_REPLY_TO=
